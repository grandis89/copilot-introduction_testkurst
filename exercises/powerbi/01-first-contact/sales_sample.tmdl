table sales_sample
	lineageTag: a4650602-f09c-452b-a87b-131ee839bb23

	/// Total sales revenue calculated as quantity × unit price
	measure 'Total Sales' = SUMX(sales_sample, sales_sample[quantity] * VALUE(sales_sample[unit_price]))
		formatString: "$"#,0.00
		lineageTag: 66381160-ea82-4a38-9446-cdbeb893066f

	/// ============================================================================
