	measure 'Total Quantity' = BLANK()
		formatString: "$"#,0.00
		lineageTag: 10000000-0000-0000-0000-000000000002

	/// Orders by Region
	/// TODO: Count the number of orders for the current region filter context (HINT: COUNTROWS(sales_sample) )
	measure 'Orders by Region' = BLANK()
		formatString: #,0
		lineageTag: 10000000-0000-0000-0000-000000000003

	/// Average Order Value
	/// TODO: Calculate the average revenue per order (HINT: DIVIDE([Total Sales], DISTINCTCOUNT(sales_sample[order_id]), 0) )
	measure 'Average Order Value' = BLANK()
		formatString: "$"#,0.00
		lineageTag: 10000000-0000-0000-0000-000000000004

